{
  "id": "openclaw-otel-plugin",
  "activation": {
    "onStartup": true
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean"
      },
      "endpoint": {
        "type": "string"
      },
      "tracePath": {
        "type": "string"
      },
      "metricsPath": {
        "type": "string"
      },
      "logsEnabled": {
        "type": "boolean"
      },
      "logsPath": {
        "type": "string"
      },
      "globalTags": {
        "type": "object",
        "description": "Deprecated compatibility field. Prefer resourceAttributes.",
        "additionalProperties": {
          "type": ["string", "number", "boolean"]
        }
      },
      "protocol": {
        "type": "string",
        "enum": ["http/protobuf"]
      },
      "serviceName": {
        "type": "string"
      },
      "headers": {
        "type": "object",
        "additionalProperties": {
          "type": "string"
        }
      },
      "sampleRate": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      },
      "flushIntervalMs": {
        "type": "number",
        "minimum": 1000
      },
      "rootSpanTtlMs": {
        "type": "number",
        "minimum": 1000
      },
      "tracePayloadDebugEnabled": {
        "type": "boolean",
        "description": "Log the exact trace export payload summary before handing it to the OTLP trace exporter."
      },
      "tracePayloadDebugTraceIds": {
        "type": "array",
        "description": "Optional trace_id allowlist for trace export payload debug logs.",
        "items": {
          "type": "string"
        }
      },
      "resourceAttributes": {
        "type": "object",
        "description": "Fixed OTEL resource attributes applied to traces, metrics, and logs.",
        "additionalProperties": {
          "type": ["string", "number", "boolean"]
        }
      }
    }
  }
}
